<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="logDir">${sys:catalina.base}/logs</Property>
        <Property name="layout">%d{DEFAULT} [%-5p] %-20c{1} :- %m%n</Property>
    </Properties>
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_OUT">
            <PatternLayout pattern="${layout}"/>
        </Console>
        <RollingFile name="FILE_HIBERNATE"
                     fileName="${logDir}/yawl_hibernate.log"
                     filePattern="${logDir}/yawl_hibernate.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_PROCLET"
                     fileName="${logDir}/yawl_procletService.log"
                     filePattern="${logDir}/yawl_procletService.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_RESOURCING"
                     fileName="${logDir}/yawl_resourceService.log"
                     filePattern="${logDir}/yawl_resourceService.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_ROOT"
                     fileName="${logDir}/default.log"
                     filePattern="${logDir}/default.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_SCHEDULING"
                     fileName="${logDir}/yawl_schedulingService.log"
                     filePattern="${logDir}/yawl_schedulingService.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_WORKLET"
                     fileName="${logDir}/yawl_workletService.log"
                     filePattern="${logDir}/yawl_workletService.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
        <RollingFile name="FILE_YAWL"
                     fileName="${logDir}/yawl_engine.log"
                     filePattern="${logDir}/yawl_engine.%d{yyyy-dd-MM}.log">
            <PatternLayout pattern="${layout}"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Logger name="org.hibernate"
                level="ERROR"
                additivity="false">
            <AppenderRef ref="FILE_HIBERNATE"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.hibernate.cache"
                level="ERROR"
                additivity="false">
            <AppenderRef ref="FILE_HIBERNATE"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="com.mchange.v2.c3p0" 
            level="WARN" 
            additivity="false">
            <AppenderRef ref="FILE_ROOT"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.yawlfoundation.yawl"
                level="WARN"
                additivity="false">
            <AppenderRef ref="FILE_YAWL"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.yawlfoundation.yawl.procletService"
                level="INFO"
                additivity="false">
            <AppenderRef ref="FILE_PROCLET"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.yawlfoundation.yawl.resourcing"
                level="INFO"
                additivity="false">
            <AppenderRef ref="FILE_RESOURCING"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.yawlfoundation.yawl.scheduling"
                level="DEBUG"
                additivity="false">
            <AppenderRef ref="FILE_SCHEDULING"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Logger name="org.yawlfoundation.yawl.worklet"
                level="INFO"
                additivity="false">
            <AppenderRef ref="FILE_WORKLET"/>
            <AppenderRef ref="STDOUT"/>
        </Logger>
        <Root level="ERROR">
            <AppenderRef ref="FILE_ROOT"/>
            <AppenderRef ref="STDOUT"/>
        </Root>
     </Loggers>
</Configuration>